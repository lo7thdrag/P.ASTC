procedure TfOtherSingle.UpdateOtherList;
var
  i,id : Integer;
  runtimePlatData : TRuntime_Platform_Library;
  predefinedData : TPredefined_Pattern;
  radarIntervalData : TRadar_Interval_List;
   overlayData : TOverlay_Definition;
  studentRoleData : TStudent_Role_List;
  gameDefaultData : TGame_Defaults;
  PODvsSNRData : TPOD_vs_SNR_Curve_Definition;
begin
  lbSingle.Items.Clear;
  lstIDsingle.Items.Clear;

  case FOtherFormShow of
    ofsRuntimePlatformLibrary:
    begin
      dmTTT.GetAllRuntimePlatformLibraryDef(FOtherList);

      for i := 0 to FOtherList.Count - 1 do
      begin
        runtimePlatData := FOtherList.Items[i];
        lbSingle.Items.AddObject(runtimePlatData.FData.Library_Name,runtimePlatData);
        lstIDsingle.Items.Add(IntToStr(TRuntime_Platform_Library(FOtherList[i]).FData.Platform_Library_Index));
      end;
    end;
    ofsPredefinedPattern:
    begin
      dmTTT.GetPredefinedPatternDef(FOtherList);

      for i := 0 to FOtherList.Count - 1 do
      begin
