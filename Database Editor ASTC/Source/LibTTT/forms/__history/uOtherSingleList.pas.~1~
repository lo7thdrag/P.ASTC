procedure TfOtherSingle.CopyRadarIntervalDefinition(const aRadarIntervalIndex,
  aNewIntervalIndex: Integer);
var
  intervalDefList : TList;
  i : Integer;
  intervalDef : TRadar_Interval_Definition;
begin
  intervalDefList := TList.Create;

  dmTTT.GetRadarIntervalDef(aRadarIntervalIndex, intervalDefList);

  for i := 0 to intervalDefList.Count - 1 do
  begin
    intervalDef := intervalDefList.Items[i];

    with intervalDef do
    begin
      FData.Interval_List_Index := aNewIntervalIndex;

      dmTTT.InsertRadarIntervalDef(FData);
    end;
  end;

  for i := 0 to intervalDefList.Count - 1 do
  begin
    intervalDef := intervalDefList.Items[i];
    intervalDef.Free;
  end;

  intervalDefList.Free;
end;

