        lbSingle.Items.AddObject(radarIntervalData.FData.Interval_List_Identifier, radarIntervalData);
        lstIDsingle.Items.Add(IntToStr(TRadar_Interval_Definition(FOtherList[i]).FData.Interval_List_Index));
      end;
    end;
    ofsGraphicalOverlays:
    begin
      dmTTT.GetAllOverlayDef(FOtherList);

      for i := 0 to FOtherList.Count - 1 do
      begin
        overlayData := FOtherList.Items[i];
        lbSingle.Items.AddObject(overlayData.FData.Overlay_Identifier,overlayData);
        lstIDsingle.Items.Add(IntToStr(TOverlay_Definition(FOtherList[i]).FData.Game_Area_Index));
      end;
    end;
    ofsStudentRoles:
    begin
      dmTTT.GetStudentRoleList(FOtherList);

      for i := 0 to FOtherList.Count - 1 do
      begin
        studentRoleData := FOtherList.Items[i];
        lbSingle.Items.AddObject(studentRoleData.FData.Role_List_Identifier,studentRoleData);
        lstIDsingle.Items.Add(IntToStr(TStudent_Role_List(FOtherList[i]).FData.Role_List_Index));
