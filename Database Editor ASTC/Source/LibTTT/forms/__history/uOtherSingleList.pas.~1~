begin
  if lbSingle.ItemIndex <> -1 then
  begin
    with frmUsage do
    begin
      UId := StrToInt(lstIDsingle.Items.Strings[lbSingle.ItemIndex]);
      name_usage := lbSingle.Items.Strings[lbSingle.ItemIndex];

      if OtherFormShow = ofsRuntimePlatformLibrary then
