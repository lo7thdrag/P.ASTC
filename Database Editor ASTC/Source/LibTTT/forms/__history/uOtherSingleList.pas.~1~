        lstIDsingle.Items.Add(IntToStr(TPOD_vs_SNR_Curve_Definition(FOtherList[i]).FData.Curve_Definition_Index));
      end;
    end;
    ofsReportEditor: ;
    ofsReportViewer: ;
  end;
end;

