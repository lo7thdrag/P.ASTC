      end
      else if OtherFormShow = ofsRadarActivationInterval then
      begin
        UIndex  :=  41;
        usage_title := 'vehicle :';
      end
      else if OtherFormShow = ofsGraphicalOverlays then
      begin
        UIndex :=  30;
      end
      else if OtherFormShow = ofsStudentRoles then
      begin
        UIndex :=  39;
      end
