procedure TfOtherSingle.btnRemoveClick(Sender: TObject);
var
  warning : Integer;
begin
  if lbSingle.ItemIndex = -1 then
    Exit;

  warning := MessageDlg('Are you sure to delete this item?', mtConfirmation,
    mbOKCancel, 0);

  if warning = mrOK then
  begin
    case FOtherFormShow of
      ofsRuntimePlatformLibrary:
      begin
        with TRuntime_Platform_Library(FSelectedObject).FData do
        begin
        if dmTTT.CekRuntime_Platform_Library_by_ResLibMap(Platform_Library_Index) > 0 then
          begin
            ShowMessage('This Runtime Platform Library is used by some Resource Allocation. Remove link ' +
              'to proceed this process.');
            Exit;
          end;
          dmTTT.DeletePlatformLibraryEntry(1, Platform_Library_Index);
          dmTTT.DeleteRuntimePlatformLibraryDef(Platform_Library_Index);
        end;
      end;
      ofsPredefinedPattern:
      begin
        with TPredefined_Pattern(FSelectedObject).FData do
        begin
        if dmTTT.CekPredefinedPattern_byScripted(Pattern_Index) > 0 then
          begin
  //          ShowMessage('Cannot delete, because is being used by some scripted point ("unchecked event" pattern type)');
  //          Exit;
            if dmTTT.CekPredefinedPattern_byRadar(Pattern_Index) > 0 then
            begin
              ShowMessage('Cannot delete, because is already used by some radar');
              Exit;
            end
            else if dmTTT.CekPredefinedPattern_bySonar(Pattern_Index) > 0 then
            begin
              ShowMessage('Cannot delete, because is already used by some sonar');
              Exit;
            end;
            dmTTT.DeleteScriptedPatternPoint(1, Pattern_Index);
          end
        else if dmTTT.CekPredefinedPattern_byPatternPoint(Pattern_Index) > 0 then
          begin
            dmTTT.DeletePatternPoint(Pattern_Index);
  //          ShowMessage('Cannot delete, because is being used by some pattern point ("checked event" pattern type)');
  //          Exit;
          end;
          dmTTT.DeletePredefined_Pattern(Pattern_Index);
        end;
      end;
      ofsRadarActivationInterval:
      begin
        with TRadar_Interval_List(FSelectedObject).FData do
        begin
          dmTTT.DeleteRadarIntervalDef(Interval_List_Index);
          dmTTT.DeleteRadarIntervalList(Interval_List_Index);
        end;
      end;
      ofsGraphicalOverlays:
      begin
        with TOverlay_Definition(FSelectedObject).FData do
        begin
//          if dmTTT.GetOverlayAtResourceAllocation(Overlay_Index) > 0 then
//          begin
//            ShowMessage('This Overlay is used by some Resource Allocation. Remove link ' +
//              'to proceed this process.');
//            Exit;
//          end;
          dmTTT.delete_Resource_Overlay_Mapping(Overlay_Index);
          dmTTT.DeleteOverlayDef(Overlay_Index);

          if not DeleteFile(vAppDBSetting.OverlayPath + '\' + Overlay_Filename + '.dat') then
            ShowMessage('Couldn''t delete file ' + Overlay_Filename + '.dat');
        end;
      end;
      ofsStudentRoles:
      begin
        with TStudent_Role_List(FSelectedObject).FData do
        begin
          if dmTTT.CekStudentRole_onResourceAllo(Role_List_Index) > 0 then
          begin
            ShowMessage('Cannot delete, because is already used by some Scenario');
            Exit;
          end;
          dmTTT.DeleteStudentRoleDef(1, Role_List_Index);
          dmTTT.DeleteStudentRoleList(Role_List_Index);
        end;
      end;
      ofsGameDefaults:
      begin
        with TGame_Defaults(FSelectedObject).FData do
        begin
//          if dmTTT.CekGameDefault_onRessourceAllo(Defaults_Index) > 0 then
//          begin
//            ShowMessage('Cannot delete, because is already used by some Scenario');
//            Exit;
//          end;
//          dmTTT.DeleteGameRainfallOnRadar(Defaults_Index);
//          dmTTT.DeleteGameCloudOnRadar(Defaults_Index);
//          dmTTT.DeleteGameSeaStateOnRadar(Defaults_Index);
//          dmTTT.DeleteGameRainfallOnESM(Defaults_Index);
//          dmTTT.DeleteGameCloudOnESM(Defaults_Index);
//          dmTTT.DeleteGameRainfallOnMissile(Defaults_Index);
//          dmTTT.DeleteGameSeaStateOnMissile(Defaults_Index);
//          dmTTT.DeleteGameRainfallOnSonar(Defaults_Index);
//          dmTTT.DeleteGameShipNoiseOnSonar(Defaults_Index);
//          dmTTT.DeleteGameSeaStateOnSonar(Defaults_Index);
//
//          dmTTT.DeleteIFFModeCode(Defaults_Index);
//
//          dmTTT.DeleteGameDefaultDef(Defaults_Index);
        end;
      end;
      ofsSNRvsPODCurve:
      begin
        with TPOD_vs_SNR_Curve_Definition(FSelectedObject).FData do
        begin
//          if dmTTT.GetSonarByPOD_vs_SNR(Curve_Definition_Index) > 0 then
//          begin
//            ShowMessage('Cannot delete, because is already used by some Sonar');
//            Exit;
//          end
